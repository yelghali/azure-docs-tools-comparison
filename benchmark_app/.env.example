# ─── Azure Content Understanding ───────────────────────────
AZURE_CU_ENDPOINT=https://YOUR-RESOURCE.cognitiveservices.azure.com
AZURE_CU_API_VERSION=2025-11-01

# ─── Azure Blob Storage (for Content Understanding URL input) ──
AZURE_STORAGE_ACCOUNT=YOUR_STORAGE_ACCOUNT
AZURE_STORAGE_CONTAINER=cu-temp
AZURE_STORAGE_KEY=           # optional — leave empty to use DefaultAzureCredential (az login)

# ─── Azure Document Intelligence (OCR) ────────────────────
DOC_INTELLIGENCE_ENDPOINT=https://YOUR-DOCINTEL.cognitiveservices.azure.com/
DOC_INTELLIGENCE_KEY=YOUR_DOC_INTEL_KEY

# ─── Azure OpenAI (base URL — deployment is selected in the app) ────
AZURE_OPENAI_BASE=https://YOUR-RESOURCE.openai.azure.com
AZURE_OPENAI_KEY=              # optional — leave empty to use DefaultAzureCredential
AZURE_OPENAI_API_VERSION=2024-10-21

# ─── Mistral Doc AI (Azure-hosted OCR) ────────────────────
# NOTE: key auth is DISABLED — uses DefaultAzureCredential
# Provide the base URL (services.ai.azure.com); the app builds the deployment path from the model name.
# Or provide a full chat completions URL directly.
MISTRAL_DOC_AI_ENDPOINT=https://YOUR-RESOURCE.services.ai.azure.com
MISTRAL_DOC_AI_KEY=
MISTRAL_DOC_AI_MODEL=mistral-document-ai-2505
